# Next.js build artifacts
.next
out
next-env.d.ts
tsconfig.tsbuildinfo

# Dependencies
node_modules

# Environment (secrets)
.env*.local
.env

# Logs — никогда не должны попадать в репозиторий
*.log
codex-*.log
codex-*.err.log
next-*.log
next-*.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# WordPress-экспорт (содержит email администратора и данные пользователей)
WordPress.*.xml

# Данные (создаются в рантайме, не должны быть в репо)
data/

# Загрузки пользователей (файлы создаются в рантайме)
public/uploads/*
!public/uploads/.gitkeep

# Файлы разработки / Claude
.claude

# Рабочие заметки (могут содержать чувствительную инфраструктурную информацию)
CONVERSATION_AND_REQUIREMENTS.md

# Изображения в корне проекта (дубли из /public/ с армянскими именами)
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.webp
